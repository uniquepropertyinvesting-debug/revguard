# ===========================================
# Next.js Environment Variables
# ===========================================

# API URL (leave empty for local, set for production)
NEXT_PUBLIC_API_URL=

# Example:
# NEXT_PUBLIC_API_URL=https://api.example.com

# ===========================================
# Stripe
# ===========================================
STRIPE_SECRET_KEY=

# ===========================================
# OpenAI
# ===========================================
# Used by the AI chat endpoint (src/app/api/ai-chat/route.ts)
OPENAI_API_KEY=

# ===========================================
# Next.js Environment Variables
# ===========================================

# API URL (leave empty for local, set for production)
NEXT_PUBLIC_API_URL=

# Example:
# NEXT_PUBLIC_API_URL=https://api.example.com

# ===========================================
# NxCode AI Gateway
# ===========================================

# API key for authenticating with studio-api.nxcode.io
# Used as a Bearer token in the Authorization header for /api/ai-chat
NXCODE_API_KEY=

# Workspace/thread identifier sent as X-Workspace-Id to the nxcode.io gateway
THREAD_ID=

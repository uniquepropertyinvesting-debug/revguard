# ===========================================
# Required for production
# ===========================================

# Supabase (already provisioned for this project)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 32-byte hex key for encrypting customer Stripe secrets at rest.
# Generate: openssl rand -hex 32
REVGUARD_ENCRYPTION_KEY=

# Public URL of the deployed app (used in dunning emails, etc.)
NEXT_PUBLIC_APP_URL=https://revguard.io

# ===========================================
# Recommended for production
# ===========================================

# Sentry error monitoring. When set, errors and warnings are forwarded.
SENTRY_DSN=

# Release tag attached to Sentry events.
RELEASE_VERSION=

# Generic JSON webhook for log forwarding (Logtail, BetterStack, etc.)
LOG_WEBHOOK_URL=

# Shared secret for the BetterStack incident webhook. Required to accept
# POSTs at /api/webhooks/betterstack. Generate: openssl rand -hex 32
BETTERSTACK_WEBHOOK_SECRET=

# ===========================================
# Optional features
# ===========================================

# OpenAI — only required if AI assistant is enabled
OPENAI_API_KEY=
